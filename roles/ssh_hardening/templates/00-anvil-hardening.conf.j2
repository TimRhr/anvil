# {{ ansible_managed }}
# Anvil SSH-Härtung (BSI SYS.1.3.A4 / CIS 5.2). Drop-in, höchste Priorität.

Port {{ ssh_port }}
AddressFamily {{ 'inet' if os_disable_ipv6 | bool else 'any' }}

# --- Authentifizierung -------------------------------------------------------
PermitRootLogin {{ ssh_permit_root_login }}
PasswordAuthentication {{ ssh_password_authentication }}
KbdInteractiveAuthentication {{ 'yes' if ssh_mfa_totp_enforce | default(false) | bool else 'no' }}
ChallengeResponseAuthentication {{ 'yes' if ssh_mfa_totp_enforce | default(false) | bool else 'no' }}
PubkeyAuthentication yes
PermitEmptyPasswords no
{% if ssh_mfa_totp_enforce | default(false) | bool %}
AuthenticationMethods publickey,keyboard-interactive
{% elif ssh_mfa_fido2_enforce | default(false) | bool %}
AuthenticationMethods publickey
PubkeyAcceptedAlgorithms sk-ssh-ed25519@openssh.com,sk-ecdsa-sha2-nistp256@openssh.com
{% else %}
AuthenticationMethods publickey
{% endif %}
UsePAM yes

# --- Zugriffskontrolle -------------------------------------------------------
AllowGroups {{ ssh_allow_groups | join(' ') }}
MaxAuthTries {{ ssh_max_auth_tries }}
MaxSessions 10
LoginGraceTime {{ ssh_login_grace_time }}
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}

# --- Funktionen einschränken -------------------------------------------------
X11Forwarding {{ ssh_x11_forwarding }}
AllowAgentForwarding {{ ssh_allow_agent_forwarding }}
AllowTcpForwarding {{ ssh_allow_tcp_forwarding }}
PermitTunnel no
PermitUserEnvironment no
Compression no
IgnoreRhosts yes
HostbasedAuthentication no

# --- Logging & Banner --------------------------------------------------------
LogLevel VERBOSE
Banner /etc/issue.net
PrintLastLog yes

# --- Kryptografie (moderne Algorithmen) --------------------------------------
KexAlgorithms {{ ssh_kex_algorithms | join(',') }}
Ciphers {{ ssh_ciphers | join(',') }}
MACs {{ ssh_macs | join(',') }}
HostKeyAlgorithms {{ ssh_host_key_algorithms | join(',') }}
{# Quell-Beschränkung (ssh_allowed_cidrs) erfolgt auf Firewall-Ebene (ufw from_ip),
   nicht via sshd Match — das vermeidet ein versehentliches Lockern der MFA. #}
