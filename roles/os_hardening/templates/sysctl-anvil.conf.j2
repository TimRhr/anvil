# {{ ansible_managed }}
# Anvil Kernel-/Netzwerk-Härtung (CIS 3.x / BSI SYS.1.3)
{% for key, value in os_sysctl_settings | dictsort %}
{{ key }} = {{ value }}
{% endfor %}
{% if os_disable_ipv6 | bool %}
# IPv6 vollständig deaktiviert (os_disable_ipv6=true)
net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
{% endif %}
