# {{ ansible_managed }}
# sudo-Rechte für den Anvil-Admin-User {{ admin_user }}
#
# Bewusst minimal/portabel gehalten: Ubuntu 26.04 nutzt sudo-rs, das nur eine
# Teilmenge der Defaults kennt (z.B. KEIN timestamp_type, KEIN logfile).
# sudo-Aktivität wird ohnehin über journald/auditd erfasst.
{% if _admin_effective_nopasswd %}
# NOPASSWD: kein Admin-Passwort gesetzt — SSH-Key ist der alleinige Faktor.
{{ admin_user }} ALL=(ALL) NOPASSWD: ALL
{% else %}
# Passwortgeschütztes sudo (admin_password_hash ist gesetzt).
{{ admin_user }} ALL=(ALL) ALL
{% endif %}
Defaults:{{ admin_user }} timestamp_timeout=5
