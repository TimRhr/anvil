#!/usr/bin/env bash
# =============================================================================
# anvil-notify-retry — stellt gespoolte ntfy-Nachrichten erneut zu
# Wird vom systemd-Timer anvil-notify-retry.timer periodisch aufgerufen.
# =============================================================================
set -euo pipefail

CONF=/etc/anvil/notify.conf
# shellcheck disable=SC1090
[[ -r "$CONF" ]] && source "$CONF"

NTFY_SERVER="${NTFY_SERVER:-}"
NTFY_TOPIC="${NTFY_TOPIC:-}"
NTFY_TOKEN="${NTFY_TOKEN:-}"
SPOOL_DIR="${SPOOL_DIR:-/var/spool/anvil-notify}"
LOG_FILE="${LOG_FILE:-/var/log/anvil/notify.log}"

[[ -d "$SPOOL_DIR" ]] || exit 0
[[ -n "$NTFY_SERVER" && -n "$NTFY_TOPIC" ]] || exit 0

declare -a auth=()
[[ -n "$NTFY_TOKEN" ]] && auth=(-H "Authorization: Bearer ${NTFY_TOKEN}")

# Jede gespoolte Datei enthält bereits das vollständige ntfy-JSON (inkl. topic),
# daher genügt ein erneuter POST an die Server-Root-URL.
shopt -s nullglob
for f in "$SPOOL_DIR"/*.json; do
  if curl -fsS --max-time 10 -H "Content-Type: application/json" "${auth[@]}" \
       -X POST "${NTFY_SERVER%/}" --data @"$f" >/dev/null 2>&1; then
    rm -f "$f"
    printf '%s RESENT %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$f" >>"$LOG_FILE" 2>/dev/null || true
  fi
done
