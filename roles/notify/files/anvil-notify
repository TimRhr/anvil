#!/usr/bin/env bash
# =============================================================================
# anvil-notify — Push-Benachrichtigung an ntfy (mit lokalem Spool/Retry)
#
# Verwendung:
#   anvil-notify [--priority N] [--title "Titel"] "Nachricht ..."
#
# Veröffentlicht via ntfy-JSON-Publish an die Server-Root-URL
# (Body: {"topic","title","message","priority"}). Schlägt der Versand fehl
# (ntfy offline), wird die Nachricht gespoolt und vom Timer anvil-notify-retry
# später erneut zugestellt. Der Aufrufer wird NIE mit einem Fehler belastet
# (Exit 0), damit Hooks robust bleiben.
# =============================================================================
set -euo pipefail

CONF=/etc/anvil/notify.conf
# shellcheck disable=SC1090
[[ -r "$CONF" ]] && source "$CONF"

NTFY_SERVER="${NTFY_SERVER:-}"
NTFY_TOPIC="${NTFY_TOPIC:-}"
NTFY_TOKEN="${NTFY_TOKEN:-}"
PRIORITY_DEFAULT="${PRIORITY_DEFAULT:-3}"
APP_NAME="${APP_NAME:-Anvil}"
SPOOL_DIR="${SPOOL_DIR:-/var/spool/anvil-notify}"
LOG_FILE="${LOG_FILE:-/var/log/anvil/notify.log}"

priority="$PRIORITY_DEFAULT"
title="$APP_NAME"
declare -a rest=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --priority) priority="${2:?}"; shift 2 ;;
    --title)    title="${2:?}"; shift 2 ;;
    --)         shift; rest+=("$@"); break ;;
    *)          rest+=("$1"); shift ;;
  esac
done
message="${rest[*]:-}"
[[ -n "$message" ]] || message="(leere Nachricht)"
# Hostnamen voranstellen für Kontext bei mehreren Servern.
message="[$(hostname -s 2>/dev/null || echo host)] $message"

# ntfy-Priorität ist 1..5 — defensiv clampen (falls ein Aufrufer noch die alte
# Gotify-Skala 0..10 verwendet), damit ntfy die Nachricht nicht mit 400 ablehnt.
case "$priority" in
  ''|*[!0-9]*) priority="$PRIORITY_DEFAULT" ;;
esac
(( priority < 1 )) && priority=1
(( priority > 5 )) && priority=5

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"; s="${s//$'\t'/\\t}"; s="${s//$'\r'/}"
  printf '%s' "$s"
}

body="$(printf '{"topic":"%s","title":"%s","message":"%s","priority":%s}' \
  "$(json_escape "$NTFY_TOPIC")" "$(json_escape "$title")" \
  "$(json_escape "$message")" "$priority")"

log_line() { printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$*" >>"$LOG_FILE" 2>/dev/null || true; }

mkdir -p "$SPOOL_DIR" 2>/dev/null || true

send() {
  [[ -n "$NTFY_SERVER" && -n "$NTFY_TOPIC" ]] || return 1
  local -a auth=()
  [[ -n "$NTFY_TOKEN" ]] && auth=(-H "Authorization: Bearer ${NTFY_TOKEN}")
  curl -fsS --max-time 10 -H "Content-Type: application/json" "${auth[@]}" \
    -X POST "${NTFY_SERVER%/}" --data "$1" >/dev/null 2>&1
}

if send "$body"; then
  log_line "SENT prio=$priority title=\"$title\""
else
  spool="$SPOOL_DIR/$(date '+%Y%m%d-%H%M%S')-$$-$RANDOM.json"
  printf '%s' "$body" >"$spool"
  log_line "SPOOLED prio=$priority title=\"$title\" -> $spool"
fi
exit 0
