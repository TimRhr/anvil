# {{ ansible_managed }}
# Anvil — Weiterleitung an zentralen Syslog/SIEM mit Spool-Queue (verlustarm).
{% if remote_syslog_protocol == 'tls' %}
global(DefaultNetstreamDriver="gtls")
# Hinweis: TLS erfordert hinterlegte CA-/Client-Zertifikate auf dem Host.
action(type="omfwd"
       target="{{ remote_syslog_host }}" port="{{ remote_syslog_port }}" protocol="tcp"
       StreamDriver="gtls" StreamDriverMode="1" StreamDriverAuthMode="x509/name"
       queue.type="LinkedList" queue.filename="anvil_fwd"
       queue.maxdiskspace="512m" queue.saveonshutdown="on"
       action.resumeRetryCount="-1")
{% else %}
action(type="omfwd"
       target="{{ remote_syslog_host }}" port="{{ remote_syslog_port }}" protocol="tcp"
       queue.type="LinkedList" queue.filename="anvil_fwd"
       queue.maxdiskspace="512m" queue.saveonshutdown="on"
       action.resumeRetryCount="-1")
{% endif %}
